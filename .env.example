# ─────────────────────────────────────────────────────────────────────────
#   halludetect environment configuration
#
#   Every variable below is OPTIONAL — the system degrades gracefully without
#   them. Setting them dramatically reduces upstream rate-limit warnings and
#   speeds up model loads. See README "Increasing rate limits" section for
#   step-by-step instructions on obtaining each key.
# ─────────────────────────────────────────────────────────────────────────

# ── Hugging Face ─────────────────────────────────────────────────────────
# Get a free read token at  https://huggingface.co/settings/tokens
# (~1,000 req/hour anonymous limit → effectively unlimited with a token).
# Any of these names work; the CLI aliases all three at startup.
HF_TOKEN=
HF_HOME=~/.cache/huggingface

# ── NCBI / PubMed (Layer 3 retrieval) ────────────────────────────────────
# Without a key NCBI limits requests to 3/sec; with one, 10/sec.
# Get a key at  https://www.ncbi.nlm.nih.gov/account/  → API Key Management.
NCBI_API_KEY=
NCBI_TOOL=halludetect
NCBI_EMAIL=research@example.com

# ── Semantic Scholar (Layer 3 retrieval) ─────────────────────────────────
# Public endpoint = ~100 req / 5 min, with key = 1 req/sec sustained.
# Apply at  https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# ── Crossref (Layer 3 retrieval) ─────────────────────────────────────────
# No key needed — just provide an email to be routed onto the polite pool
# (better latency + stability).
CROSSREF_MAILTO=research@example.com

# ── Runtime ──────────────────────────────────────────────────────────────
HALLUDETECT_CONFIG=configs/default.yaml
HALLUDETECT_LOG_LEVEL=INFO
HALLUDETECT_OFFLINE=0          # 1 forces heuristic backends, no network
