# ── Hugging Face ────────────────────────────────────────
HF_HOME=~/.cache/huggingface
HUGGINGFACE_HUB_TOKEN=

# ── Layer 3: External APIs ──────────────────────────────
# NCBI E-utilities (PubMed)  — recommended by NCBI for >3 req/s
NCBI_API_KEY=
NCBI_TOOL=halludetect
NCBI_EMAIL=research@example.com

# Semantic Scholar  — optional, raises rate limit
SEMANTIC_SCHOLAR_API_KEY=

# Crossref  — polite pool email
CROSSREF_MAILTO=research@example.com

# ── Runtime ─────────────────────────────────────────────
HALLUDETECT_CONFIG=configs/default.yaml
HALLUDETECT_LOG_LEVEL=INFO
HALLUDETECT_OFFLINE=0          # 1 forces heuristic backends, no network
